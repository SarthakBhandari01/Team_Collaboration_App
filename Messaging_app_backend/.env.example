PORT = 3000

JWT_SECRET = "your_jwt_secret_here"

JWT_EXPIRY = "1d"

DEV_DB_URL = "mongodb+srv://username:password@cluster.mongodb.net/dbname"

PROD_DB_URL = "mongodb+srv://username:password@cluster.mongodb.net/dbname"

# Resend Email Configuration
# Sign up at https://resend.com to get your API key (free tier: 3000 emails/month)

# From email address - use "onboarding@resend.dev" for testing or your verified domain
MAIL_ID = "Team Collaboration <onboarding@resend.dev>"

# Frontend URL for CORS and email links
FRONTEND_URL = "http://localhost:5173"
